# =============================================================================
# Kat Dashboard — Environment Variables
# Copy to .env.local and fill in values. Never commit secrets.
# =============================================================================

# App
NEXT_PUBLIC_APP_NAME=Kat
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Spring Boot REST API
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Discord OAuth2
# Client ID es PÚBLICO → va en el frontend (.env.local)
# Client SECRET es PRIVADO → solo en Spring Boot, NUNCA aquí
NEXT_PUBLIC_DISCORD_CLIENT_ID=1234567890123456789
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
# Tras invitar al bot — DEBE estar en Discord OAuth2 → Redirects (exacto, sin / final)
NEXT_PUBLIC_DISCORD_BOT_REDIRECT_URI=http://localhost:3000/auth/bot-callback
# Permisos del bot (bitfield) — ajustar según tu bot
NEXT_PUBLIC_DISCORD_BOT_PERMISSIONS=268435518

# Feature flags (optional)
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
